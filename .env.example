# Copy to .env (which is gitignored) and fill in.

# SEC EDGAR — no API key, but SEC requires a User-Agent identifying the requester.
# Format: "Your Name your.email@example.com"
SEC_IDENTITY="Andrew See andrew.see@colorado.edu"

# Congress.gov — free key from https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=

# FRED — free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Alpha Vantage — free key from https://www.alphavantage.co/support/#api-key
# (instant form, no email verification). Used for the NEWS_SENTIMENT endpoint
# which returns finance news with pre-tagged per-ticker sentiment scores.
# Free tier: 25 requests/day, 5/min — but each request returns up to 1000 articles.
ALPHAVANTAGE_API_KEY=

# Anthropic — Claude API for hypothesis generation in Phase 1. Free $5 signup
# credit at https://console.anthropic.com/. Recommended model:
# claude-haiku-4-5 (fast + cheap for prompt iteration).
ANTHROPIC_API_KEY=

# Ollama — optional local LLM fallback. If running ollama serve locally,
# set OLLAMA_HOST=http://localhost:11434 (the default). Pull a model first:
#   ollama pull qwen2.5:7b-instruct
OLLAMA_HOST=http://localhost:11434

# Reddit — DORMANT. As of 2026 Reddit pushes new devs to Devvit (in-app
# platform) rather than the classic OAuth API. The reddit_ingest.py module
# is left in place but unused; sentiment ingest uses StockTwits instead
# (no key required). Fill these in only if you successfully register a
# classic 'script' app at https://www.reddit.com/prefs/apps.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="llm-trade-lab/0.1 (research)"
